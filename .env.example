# Supabase (already in your project)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Groq API Keys ─────────────────────────────────────────────────────────────
# Add as many as you have. The app rotates automatically on rate limits.
# Get keys at: console.groq.com
# To add more later: just add VITE_GROQ_KEY_4, VITE_GROQ_KEY_5, etc. No code changes needed.
VITE_GROQ_KEY_1=gsk_your_first_key_here
VITE_GROQ_KEY_2=gsk_your_second_key_here
VITE_GROQ_KEY_3=gsk_your_third_key_here
# VITE_GROQ_KEY_4=gsk_add_when_you_get_one
# VITE_GROQ_KEY_5=gsk_add_when_you_get_one
